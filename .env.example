# === Research-Claw Environment Variables ===
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- LLM API Keys (at least one required) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ZAI_API_KEY=

# --- Proxy (optional, for China users) ---
HTTP_PROXY=
HTTPS_PROXY=
# Example: HTTP_PROXY=http://127.0.0.1:7890

# --- Wentor Platform (optional, future) ---
# WENTOR_API_KEY=
# WENTOR_API_URL=https://wentor.ai/api/v1
